# ── RESEND (email alerts) ────────────────────────────────────────────────────
# Sign up free at resend.com → API Keys → Create Key
# Free tier: 3,000 emails/month, 100/day
RESEND_API_KEY=re_your_api_key_here

# From address — must be on a domain verified in Resend
# For testing without a domain: use onboarding@resend.dev
RESEND_FROM=MOMLS Alerts <alerts@yourdomain.com>

# Your deployed site URL (used in email links and unsubscribe URLs)
SITE_URL=https://momls.netlify.app
